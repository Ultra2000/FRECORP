# ============================================================================
# .env de PRODUCTION — frecorp.fr (landing site + blog)
# Hébergement : O2switch mutualisé / SQLite
#
# 1. Copier ce fichier vers .env sur le serveur (PAS dans le repo Git)
# 2. Remplacer toutes les valeurs __TO_FILL__
# 3. Générer une nouvelle clé : php artisan key:generate
# 4. Vider les caches : php artisan config:clear && php artisan cache:clear
# ============================================================================

APP_NAME=FRECORP
APP_ENV=production
APP_KEY=__TO_FILL__
APP_DEBUG=false
APP_URL=https://frecorp.fr

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_TIMEZONE=Europe/Paris

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# ----------------------------------------------------------------------------
# Logs : niveau "error" en prod pour éviter de remplir le disque
# ----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# ----------------------------------------------------------------------------
# Base de données : SQLite — chemin ABSOLU vers le fichier
# Sur O2switch, exemple : /home/USERNAME/frecorp.fr/database/database.sqlite
# ----------------------------------------------------------------------------
DB_CONNECTION=sqlite
DB_DATABASE=__ABSOLUTE_PATH_TO_DATABASE_SQLITE__
DB_FOREIGN_KEYS=true

# ----------------------------------------------------------------------------
# Sessions : cookies sécurisés HTTPS uniquement
# ----------------------------------------------------------------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.frecorp.fr
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# ----------------------------------------------------------------------------
# Cache & file system
# ----------------------------------------------------------------------------
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=database
CACHE_STORE=database

# ----------------------------------------------------------------------------
# Email : SMTP O2switch
# Créer la boîte contact@frecorp.fr depuis cPanel, récupérer les identifiants
# ----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=__SMTP_HOST__
MAIL_PORT=465
MAIL_USERNAME=contact@frecorp.fr
MAIL_PASSWORD=__TO_FILL__
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=contact@frecorp.fr
MAIL_FROM_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# Vite : nom de l'app pour les variables JS publiques
# ----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"

# ----------------------------------------------------------------------------
# Sécurité : forcer HTTPS et HSTS (à activer après vérification SSL)
# ----------------------------------------------------------------------------
FORCE_HTTPS=true
